      <div class="bar-row"><div class="bar-label">Mixture & Aligation</div><div class="bar-bg"><div class="bar-fill" style="width:43.9%;background:#e67e2222;border:1px solid #e67e22;color:#f0b27a">430</div></div></div>
      <div style="margin-top:10px;font-size:11px;color:#7f8ea3">Partnership & Probability: ~100% of students have NEVER attempted these</div>
    </div>
  </div>
</div>

<!-- ═══════ SUBJECTS ═══════ -->
<div id="tab-subjects" class="panel">
  <div class="filter-bar">
    <select id="subj-filter" onchange="renderChapters()">
      <option value="all">All Subjects</option>
      <option value="ENGLISH">English</option>
      <option value="Quantitative Aptitude">Quantitative Aptitude</option>
      <option value="Verbal Reasoning">Verbal Reasoning</option>
    </select>
    <select id="status-filter" onchange="renderChapters()">
      <option value="all">All Statuses</option>
      <option value="Blind Spot">Blind Spot</option>
