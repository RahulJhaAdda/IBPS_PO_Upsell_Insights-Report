      <div class="bar-row"><div class="bar-label">Probability (Quant)</div><div class="bar-bg"><div class="bar-fill" style="width:97.3%;background:#e67e2222;border:1px solid #e67e22;color:#f0b27a">954</div></div></div>
      <div class="bar-row"><div class="bar-label">Age (Quant)</div><div class="bar-bg"><div class="bar-fill" style="width:95.4%;background:#e67e2222;border:1px solid #e67e22;color:#f0b27a">935</div></div></div>
      <div class="bar-row"><div class="bar-label">Number System</div><div class="bar-bg"><div class="bar-fill" style="width:82.6%;background:#e67e2222;border:1px solid #e67e22;color:#f0b27a">810</div></div></div>
      <div class="bar-row"><div class="bar-label">Average (Quant)</div><div class="bar-bg"><div class="bar-fill" style="width:62.3%;background:#e67e2222;border:1px solid #e67e22;color:#f0b27a">611</div></div></div>
      <div class="bar-row"><div class="bar-label">Mensuration (Quant)</div><div class="bar-bg"><div class="bar-fill" style="width:60.5%;background:#e67e2222;border:1px solid #e67e22;color:#f0b27a">593</div></div></div>
