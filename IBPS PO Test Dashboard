<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>IBPS PO Prelims — Upsell Intelligence Dashboard</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<style>
  *{box-sizing:border-box;margin:0;padding:0}
  body{font-family:'Segoe UI',Arial,sans-serif;background:#0f1117;color:#e8e8e8;min-height:100vh}
  :root{
    --red:#e74c3c;--lred:#fadbd8;--dred:#922b21;
    --amb:#e67e22;--lamb:#fdebd0;--damb:#9c5a00;
    --blu:#2980b9;--lblu:#d6eaf8;--dblu:#1a5276;
    --grn:#27ae60;--lgrn:#d5f5e3;--dgrn:#1e8449;
    --gry:#95a5a6;--dgry:#2c3e50;--surface:#1a1d27;--surface2:#22263a;--border:#2e3250
  }
  header{background:linear-gradient(135deg,#1a1d27 0%,#0f1117 100%);border-bottom:1px solid var(--border);padding:16px 28px;display:flex;align-items:center;justify-content:space-between}
  header h1{font-size:17px;font-weight:600;color:#fff;letter-spacing:.3px}
  header span{font-size:12px;color:#7f8ea3;background:#22263a;padding:4px 12px;border-radius:20px;border:1px solid var(--border)}
  .tabs{display:flex;gap:0;background:var(--surface);border-bottom:1px solid var(--border);padding:0 20px}
  .tab{padding:12px 20px;font-size:13px;font-weight:500;color:#7f8ea3;cursor:pointer;border-bottom:2px solid transparent;transition:all .2s;white-space:nowrap}
  .tab.active{color:#fff;border-bottom-color:#4f8ef7}
  .tab:hover:not(.active){color:#b0b8c8}
  .panel{display:none;padding:24px 24px}
  .panel.active{display:block}
  .metric-row{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:22px}
  .mcard{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:16px 18px}
  .mcard .label{font-size:11px;color:#7f8ea3;text-transform:uppercase;letter-spacing:.05em;margin-bottom:6px}
  .mcard .value{font-size:28px;font-weight:600;color:#fff;line-height:1}
  .mcard .sub{font-size:11px;color:#7f8ea3;margin-top:4px}
  .mcard.red{border-left:3px solid var(--red)}
  .mcard.amb{border-left:3px solid var(--amb)}
  .mcard.grn{border-left:3px solid var(--grn)}
  .mcard.blu{border-left:3px solid var(--blu)}
  .chart-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:22px}
  .chart-grid.three{grid-template-columns:1fr 1fr 1fr}
  .ccard{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:18px}
  .ccard h3{font-size:13px;font-weight:500;color:#b0b8c8;margin-bottom:14px}
  .ccard.full{grid-column:1/-1}
  .bar-row{display:flex;align-items:center;gap:10px;margin-bottom:8px}
  .bar-label{font-size:11px;color:#7f8ea3;width:150px;flex-shrink:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .bar-bg{flex:1;background:#22263a;border-radius:3px;height:18px;overflow:hidden}
  .bar-fill{height:100%;border-radius:3px;display:flex;align-items:center;padding-left:6px;font-size:10px;font-weight:600;transition:width .6s}
  .bar-val{font-size:11px;color:#7f8ea3;width:34px;text-align:right;flex-shrink:0}
  /* filter bar */
  .filter-bar{display:flex;gap:10px;margin-bottom:18px;flex-wrap:wrap;align-items:center}
  .filter-bar input,.filter-bar select{background:var(--surface);border:1px solid var(--border);border-radius:6px;color:#e8e8e8;font-size:12px;padding:7px 12px;outline:none}
  .filter-bar input{width:220px}
  .filter-bar select{width:140px}
  .filter-bar input:focus,.filter-bar select:focus{border-color:#4f8ef7}
  /* student table */
  .tbl-wrap{overflow-x:auto;border-radius:8px;border:1px solid var(--border)}
  table{width:100%;border-collapse:collapse;font-size:12px}
  thead tr{background:#1f2535}
  th{padding:10px 12px;text-align:left;font-weight:600;font-size:11px;color:#7f8ea3;text-transform:uppercase;letter-spacing:.04em;white-space:nowrap;border-bottom:1px solid var(--border)}
  td{padding:9px 12px;border-bottom:1px solid var(--border);vertical-align:top;line-height:1.5}
  tr:last-child td{border-bottom:none}
  tr:hover td{background:#1f2535}
  .badge{display:inline-block;font-size:10px;font-weight:600;padding:2px 8px;border-radius:4px;white-space:nowrap}
  .badge.Critical{background:var(--lred);color:var(--dred)}
  .badge.Developing{background:var(--lamb);color:var(--damb)}
  .badge.Moderate{background:var(--lblu);color:var(--dblu)}
  .badge.Strong{background:var(--lgrn);color:var(--dgrn)}
  .tag{display:inline-block;font-size:10px;padding:2px 7px;border-radius:3px;margin:1px;background:#22263a;color:#9aa3b4;border:1px solid #2e3250}
  .tag.weak{background:#3d1a1a;color:#f1948a;border-color:#7b241c}
  .tag.strong{background:#1a3d22;color:#82e0aa;border-color:#1e8449}
  .tag.np{background:#3d2e1a;color:#f0b27a;border-color:#9c5a00}
  .upsell-lines{font-size:11px;color:#9aa3b4;line-height:1.6}
  .upsell-lines .l1{color:#e8e8e8;margin-bottom:3px}
  .readiness-bar{width:70px;height:8px;background:#22263a;border-radius:4px;overflow:hidden;display:inline-block;vertical-align:middle;margin-right:6px}
  .readiness-fill{height:100%;border-radius:4px}
  /* chapter table */
  .chap-status{font-size:10px;font-weight:600;padding:2px 8px;border-radius:3px;display:inline-block}
  .cs-bs{background:#f1948a22;color:#f1948a;border:1px solid #922b21}
  .cs-cw{background:#e74c3c22;color:#e74c3c;border:1px solid #c0392b}
  .cs-wk{background:#f0b27a22;color:#f0b27a;border:1px solid #9c5a00}
  .cs-mo{background:#85c1e922;color:#85c1e9;border:1px solid #1a5276}
  .cs-st{background:#82e0aa22;color:#82e0aa;border:1px solid #1e8449}
  .pct-cell{display:flex;align-items:center;gap:6px}
  .mini-bar{flex:1;height:6px;background:#22263a;border-radius:3px;overflow:hidden;min-width:40px}
  .mini-fill{height:100%;border-radius:3px}
  .page-info{font-size:11px;color:#7f8ea3;margin-top:12px;text-align:center}
  .pg-btn{background:var(--surface);border:1px solid var(--border);border-radius:5px;color:#b0b8c8;font-size:11px;padding:5px 12px;cursor:pointer;margin:0 3px}
  .pg-btn:hover{background:var(--surface2);color:#fff}
  .pg-btn.active{background:#1a3d5c;border-color:#2980b9;color:#fff}
  .subj-pill{font-size:10px;padding:2px 7px;border-radius:3px;font-weight:600}
  .sp-eng{background:#1a3d5c;color:#85c1e9}
  .sp-qnt{background:#3d1a1a;color:#f1948a}
  .sp-vr{background:#1a3d22;color:#82e0aa}
  .score-cell{font-weight:600}
  .no-data{text-align:center;padding:30px;color:#7f8ea3;font-size:13px}
</style>
</head>
<body>

<header>
  <h1>📊 IBPS PO Prelims — Upsell Intelligence Dashboard</h1>
  <span id="ts">Loading...</span>
</header>

<div class="tabs">
  <div class="tab active" onclick="switchTab('overview')">Overview</div>
  <div class="tab" onclick="switchTab('subjects')">Subject & Chapter Analysis</div>
  <div class="tab" onclick="switchTab('students')">Student-wise Upsell (982)</div>
  <div class="tab" onclick="switchTab('testbands')">Test Volume Bands</div>
</div>

<!-- ═══════ OVERVIEW ═══════ -->
