  let d=[...STUDENTS];
  if(q) d=d.filter(s=>String(s.email).toLowerCase().includes(q)||String(s.userid).includes(q));
  if(co!=='all') d=d.filter(s=>s.cohort===co);
  if(su!=='all') d=d.filter(s=>s.weakestSubject===su);
  if(so==='readiness_asc') d.sort((a,b)=>a.readiness-b.readiness);
  else if(so==='readiness_desc') d.sort((a,b)=>b.readiness-a.readiness);
  else if(so==='tests_desc') d.sort((a,b)=>b.tests-a.tests);
  else d.sort((a,b)=>b.weak-a.weak);
  return d;
}
function renderStudents(){
  sPage=0;
  const d=getFilteredStudents();
  document.getElementById('s-count').textContent=`${d.length} students`;
  renderStudentPage(d);
  renderPagination(d);
}
function renderStudentPage(d){
  const start=sPage*PAGE, slice=d.slice(start,start+PAGE);
  const rColor=r=>r>=65?'#27ae60':r>=45?'#2980b9':r>=25?'#e67e22':'#e74c3c';
  document.getElementById('student-body').innerHTML = slice.length===0
    ? `<tr><td colspan="11" class="no-data">No students match the current filters.</td></tr>`
    : slice.map((s,i)=>`
    <tr>
      <td style="color:#7f8ea3">${start+i+1}</td>
      <td style="font-weight:600;color:#85c1e9">${s.userid}</td>
      <td style="font-size:11px;color:#9aa3b4">${s.email}</td>
      <td style="text-align:center">${s.tests}</td>
      <td><span class="badge ${s.cohort}">${s.cohort}</span></td>
      <td>
        <div style="display:flex;align-items:center;gap:6px">
          <div class="readiness-bar"><div class="readiness-fill" style="width:${s.readiness}%;background:${rColor(s.readiness)}"></div></div>
          <span style="font-weight:600;color:${rColor(s.readiness)}">${s.readiness}%</span>
        </div>
      </td>
      <td style="text-align:center">
        <span style="color:#82e0aa">${s.strong}</span>/<span style="color:#f1948a">${s.weak}</span>/<span style="color:#f0b27a">${s.notPracticed}</span>
      </td>
      <td>${s.weakChapters.map(c=>`<span class="tag weak">${c}</span>`).join('')}</td>
      <td>${s.notPracticedChapters.map(c=>`<span class="tag np">${c}</span>`).join('')}</td>
      <td>${s.strongChapters.map(c=>`<span class="tag strong">${c}</span>`).join('')}</td>
      <td class="upsell-lines"><div class="l1">${s.line1}</div><div>${s.line2}</div></td>
    </tr>`).join('');
  document.getElementById('s-page-info').textContent=`Showing ${start+1}–${Math.min(start+PAGE,d.length)} of ${d.length} students`;
}
function renderPagination(d){
  const total=Math.ceil(d.length/PAGE);
  const pg=document.getElementById('s-pagination');
  pg.innerHTML='';
  for(let i=0;i<total;i++){
    const b=document.createElement('button');
    b.className='pg-btn'+(i===sPage?' active':'');
    b.textContent=i+1;
    b.onclick=(()=>{const p=i;return()=>{sPage=p;renderStudentPage(d);renderPagination(d);pg.parentElement.scrollIntoView({behavior:'smooth',block:'nearest'});}})();
    pg.appendChild(b);
  }
}

// ── BAND CHART ──
let bandChartInstance=null;
function renderBandChart(){
  if(bandChartInstance) return;
  const labels=BANDS.map(b=>b.band+' tests');
  const vals=BANDS.map(b=>b.avgReadiness);
  const counts=BANDS.map(b=>b.students);
  bandChartInstance=new Chart(document.getElementById('bandChart'),{
    type:'bar',
    data:{
      labels,
      datasets:[{
        label:'Avg Readiness %',
        data:vals,
        backgroundColor:['#e74c3c99','#e67e2299','#2980b999','#9b59b699','#27ae6099'],
        borderColor:['#e74c3c','#e67e22','#2980b9','#9b59b6','#27ae60'],
        borderWidth:1.5,
        borderRadius:4
      }]
    },
    options:{
      responsive:true,maintainAspectRatio:false,
      plugins:{
        legend:{display:false},
        tooltip:{callbacks:{label:ctx=>`Avg Readiness: ${ctx.raw}% | Students: ${counts[ctx.dataIndex]}`}}
      },
      scales:{
        x:{ticks:{color:'#7f8ea3',font:{size:11}},grid:{color:'#1f2535'}},
        y:{min:0,max:60,ticks:{color:'#7f8ea3',font:{size:11},callback:v=>v+'%'},grid:{color:'#1f2535'}}
      }
    }
  });
}

// ── INIT ──
renderChapters();
renderStudents();
</script>
