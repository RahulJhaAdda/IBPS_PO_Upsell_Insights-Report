      </tr></thead>
      <tbody id="chap-body"></tbody>
    </table>
  </div>
</div>

<!-- ═══════ STUDENTS ═══════ -->
<div id="tab-students" class="panel">
  <div class="filter-bar">
    <input type="text" id="s-search" placeholder="Search email / user ID..." oninput="renderStudents()">
    <select id="s-cohort" onchange="renderStudents()">
      <option value="all">All Cohorts</option>
      <option value="Critical">Critical (&lt;25%)</option>
      <option value="Developing">Developing (25-44%)</option>
      <option value="Moderate">Moderate (45-64%)</option>
      <option value="Strong">Strong (65%+)</option>
    </select>
    <select id="s-subject" onchange="renderStudents()">
      <option value="all">All Weak Subjects</option>
      <option value="Quantitative Aptitude">Weakest: Quant</option>
      <option value="ENGLISH">Weakest: English</option>
      <option value="Verbal Reasoning">Weakest: Verbal</option>
    </select>
    <select id="s-sort" onchange="renderStudents()">
      <option value="readiness_asc">Readiness ↑ (worst first)</option>
      <option value="readiness_desc">Readiness ↓ (best first)</option>
      <option value="tests_desc">Tests ↓</option>
      <option value="weak_desc">Weak Chapters ↓</option>
    </select>
    <span id="s-count" style="font-size:11px;color:#7f8ea3;margin-left:8px"></span>
  </div>
  <div class="tbl-wrap">
    <table>
      <thead><tr>
        <th>#</th><th>User ID</th><th>Email</th><th>Tests</th><th>Cohort</th>
        <th>Readiness</th><th>Chapters (S/W/NP)</th>
        <th>Weak Chapters</th><th>Not Practiced</th><th>Strongest</th>
        <th>Upsell Lines</th>
      </tr></thead>
      <tbody id="student-body"></tbody>
    </table>
  </div>
  <div id="s-pagination" style="display:flex;gap:6px;margin-top:14px;justify-content:center;flex-wrap:wrap"></div>
  <div id="s-page-info" class="page-info"></div>
</div>

<!-- ═══════ TEST BANDS ═══════ -->
<div id="tab-testbands" class="panel">
  <div class="metric-row" style="grid-template-columns:repeat(5,1fr)">
    <div class="mcard red"><div class="label">&lt;250 Tests</div><div class="value">235</div><div class="sub">Avg readiness: 38.6%</div></div>
    <div class="mcard amb"><div class="label">250–350 Tests</div><div class="value">316</div><div class="sub">Avg readiness: 38.3%</div></div>
    <div class="mcard blu"><div class="label">350–500 Tests</div><div class="value">219</div><div class="sub">Avg readiness: 41.1%</div></div>
    <div class="mcard blu" style="border-left-color:#9b59b6"><div class="label">500–750 Tests</div><div class="value">137</div><div class="sub">Avg readiness: 44.8%</div></div>
    <div class="mcard grn"><div class="label">750+ Tests</div><div class="value">75</div><div class="sub">Avg readiness: 47.5%</div></div>
  </div>
  <div class="ccard" style="margin-bottom:16px">
    <h3>Readiness vs test volume — does more practice = better readiness?</h3>
    <div style="position:relative;height:220px;margin-top:8px"><canvas id="bandChart" role="img" aria-label="Bar chart of avg readiness by test volume band">More tests correlates with slightly higher readiness.</canvas></div>
    <div style="font-size:11px;color:#7f8ea3;margin-top:12px">⚠️ Insight: Students with 750+ tests have only 47.5% avg readiness. Volume ≠ quality. Strategy gap — key upsell angle.</div>
  </div>
  <div class="ccard">
    <h3>Test band upsell strategy</h3>
    <table style="width:100%;font-size:12px">
      <thead><tr style="background:#1f2535">
        <th style="padding:10px;text-align:left;color:#7f8ea3;font-size:11px">Band</th>
        <th style="padding:10px;text-align:left;color:#7f8ea3;font-size:11px">Students</th>
        <th style="padding:10px;text-align:left;color:#7f8ea3;font-size:11px">Avg Readiness</th>
        <th style="padding:10px;text-align:left;color:#7f8ea3;font-size:11px">Upsell Insight</th>
      </tr></thead>
      <tbody>
        <tr><td style="padding:10px;color:#f1948a;font-weight:600">&lt;250 tests</td><td style="padding:10px">235</td><td style="padding:10px">38.6%</td><td style="padding:10px;color:#9aa3b4">Low engagement — likely just enrolled; needs orientation call + quick win plan to activate</td></tr>
