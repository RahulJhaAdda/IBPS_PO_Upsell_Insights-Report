      <div class="bar-row"><div class="bar-label">Time & Work (Quant)</div><div class="bar-bg"><div class="bar-fill" style="width:92.7%;background:#e74c3c22;border:1px solid #e74c3c;color:#f1948a">416</div></div></div>
      <div class="bar-row"><div class="bar-label">Speed Time Distance</div><div class="bar-bg"><div class="bar-fill" style="width:89.1%;background:#e74c3c22;border:1px solid #e74c3c;color:#f1948a">400</div></div></div>
      <div class="bar-row"><div class="bar-label">Profit & Loss (Quant)</div><div class="bar-bg"><div class="bar-fill" style="width:87.3%;background:#e74c3c22;border:1px solid #e74c3c;color:#f1948a">392</div></div></div>
      <div class="bar-row"><div class="bar-label">Simple & Comp. Int.</div><div class="bar-bg"><div class="bar-fill" style="width:85.3%;background:#e74c3c22;border:1px solid #e74c3c;color:#f1948a">383</div></div></div>
      <div class="bar-row"><div class="bar-label">Vocabulary (English)</div><div class="bar-bg"><div class="bar-fill" style="width:83.3%;background:#e74c3c22;border:1px solid #e74c3c;color:#f1948a">374</div></div></div>
      <div class="bar-row"><div class="bar-label">Cloze Test (English)</div><div class="bar-bg"><div class="bar-fill" style="width:72.4%;background:#e74c3c22;border:1px solid #e74c3c;color:#f1948a">325</div></div></div>
