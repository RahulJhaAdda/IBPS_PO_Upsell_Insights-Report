// ── CHAPTERS ──
function renderChapters(){
  const subj = document.getElementById('subj-filter').value;
  const st   = document.getElementById('status-filter').value;
  const srt  = document.getElementById('sort-ch').value;
  let d = [...CHAPTERS];
  if(subj!=='all') d=d.filter(c=>c.subject===subj);
  if(st!=='all')   d=d.filter(c=>c.status===st);
  if(srt==='weak') d.sort((a,b)=>b.weak-a.weak);
  else if(srt==='acc') d.sort((a,b)=>a.acc-b.acc);
  else d.sort((a,b)=>b.notPracticed-a.notPracticed);
  
  const spMap={'ENGLISH':'sp-eng','Quantitative Aptitude':'sp-qnt','Verbal Reasoning':'sp-vr'};
  const csMap={'Blind Spot':'cs-bs','Critical Weak':'cs-cw','Weak':'cs-wk','Moderate':'cs-mo','Strong':'cs-st'};
  const accColor = v => v>=65?'#27ae60':v>=50?'#2980b9':v>=30?'#e67e22':'#e74c3c';
  
  document.getElementById('chap-body').innerHTML = d.map(c=>`
    <tr>
      <td><span class="subj-pill ${spMap[c.subject]||''}">${c.subject==='Quantitative Aptitude'?'Quant':c.subject==='Verbal Reasoning'?'Verbal':c.subject}</span></td>
      <td style="font-weight:500;color:#e8e8e8">${c.chapter}</td>
      <td><div class="pct-cell"><div class="mini-bar"><div class="mini-fill" style="width:${c.acc}%;background:${accColor(c.acc)}"></div></div><span class="score-cell" style="color:${accColor(c.acc)}">${c.acc}%</span></div></td>
      <td><div class="pct-cell"><div class="mini-bar"><div class="mini-fill" style="width:${c.attemptRate}%;background:#7f8ea3"></div></div>${c.attemptRate}%</div></td>
      <td style="color:#f1948a;font-weight:600">${c.weak}</td>
      <td style="color:#82e0aa;font-weight:600">${c.strong}</td>
      <td style="color:#f0b27a;font-weight:600">${c.notPracticed}</td>
      <td><span class="chap-status ${csMap[c.status]||''}">${c.status}</span></td>
    </tr>`).join('');
}

